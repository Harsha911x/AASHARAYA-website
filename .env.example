# ─────────────────────────────────────────────
# Aashraya — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# ── Email (required for contact form to send mail) ──────────────────
# OPTION A — Gmail App Password (recommended, free)
#   1. Go to myaccount.google.com → Security → 2-Step Verification → App passwords
#   2. Create an app password for "Mail" on "Other device" (name it "Aashraya")
#   3. Paste the 16-char password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=harsha.7x@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# OPTION B — Other SMTP provider (e.g. Brevo / SendGrid / Zoho)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_smtp_key

# ── Site URL (used for sitemap) ──────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://aashraya.in
